{
  "name": "token-efficiency-agent",
  "displayName": "Token Efficiency Agent",
  "description": "Optimise the selected prompt text and show tokens saved. Wraps the TEA Python package.",
  "version": "0.2.0",
  "publisher": "optimum-ai",
  "icon": "icon.png",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["AI", "Machine Learning", "Other"],
  "keywords": ["llm", "tokens", "prompt", "optimization", "cost", "openai", "anthropic"],
  "galleryBanner": { "color": "#1A5276", "theme": "dark" },
  "repository": {
    "type": "git",
    "url": "https://github.com/Optimumailabs/Token-Efficiency-Agent"
  },
  "bugs": { "url": "https://github.com/Optimumailabs/Token-Efficiency-Agent/issues" },
  "homepage": "https://github.com/Optimumailabs/Token-Efficiency-Agent#readme",
  "license": "MIT",
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "tea.optimizeSelection",
        "title": "TEA: Optimise selected prompt"
      },
      {
        "command": "tea.scoreSelection",
        "title": "TEA: Score selected prompt"
      }
    ],
    "menus": {
      "editor/context": [
        { "command": "tea.optimizeSelection", "when": "editorHasSelection", "group": "1_modification" },
        { "command": "tea.scoreSelection", "when": "editorHasSelection", "group": "1_modification" }
      ]
    },
    "configuration": {
      "title": "Token Efficiency Agent",
      "properties": {
        "tea.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter that has the `tea` package installed."
        },
        "tea.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model id used for token counting."
        },
        "tea.aggressive": {
          "type": "boolean",
          "default": false,
          "description": "Also drop low-relevance context (needs a query in the first line)."
        },
        "tea.logDir": {
          "type": "string",
          "default": "",
          "description": "If set, every optimise call is logged to this directory."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'no build step; plain JS'",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.21.0"
  }
}
